{
  "name": "video-converter-pro",
  "version": "1.0.0",
  "description": "Portable Video Converter - Convert, compress, and optimize videos for any device",
  "main": "main.js",
  "author": "Mezamii SAS <contact@mezamii.com> (https://mezamii.com)",
  "license": "MIT",
  "homepage": "https://mezamii.github.io/video-converter-pro/",
  "repository": {
    "type": "git",
    "url": "https://github.com/mezamii/video-converter-pro.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "generate:icons": "node scripts/generate-icons.js",
    "prebuild:win": "node scripts/generate-icons.js",
    "build:win": "electron-builder --win portable",
    "build:mac": "electron-builder --mac dmg",
    "build:linux": "electron-builder --linux AppImage",
    "build:all": "electron-builder --win portable --mac dmg --linux AppImage"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "sharp": "^0.33.2"
  },
  "build": {
    "appId": "com.videoconverter.pro",
    "productName": "Video Converter Pro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**",
      "node_modules/@ffprobe-installer/**"
    ],
    "win": {
      "target": "portable",
      "icon": "src/assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icon.png"
    },
    "portable": {
      "artifactName": "VideoConverterPro-${version}-Portable.exe"
    }
  }
}
